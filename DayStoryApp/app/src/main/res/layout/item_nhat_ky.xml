<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"

    android:layout_marginHorizontal="18dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="4dp"

    app:cardBackgroundColor="#FFFDFB"
    app:cardCornerRadius="28dp"
    app:cardElevation="4dp"
    app:strokeColor="#F3E8DE"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:padding="14dp">

        <!-- IMAGE -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="220dp"

            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/imgNhatKy"

                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:layout_marginTop="14dp"

            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- DATE -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:background="#F7EFE8"

                android:gravity="center_vertical"
                android:orientation="horizontal"

                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                android:paddingBottom="5dp">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"

                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="#A08167"/>

                <TextView
                    android:id="@+id/txtNgay"

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:layout_marginStart="5dp"

                    android:maxWidth="82dp"
                    android:singleLine="true"

                    android:text="13/05/2026"

                    android:textColor="#9A816A"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- MOOD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutMood"

                android:layout_width="34dp"
                android:layout_height="34dp"

                android:layout_marginStart="8dp"

                app:cardBackgroundColor="#FFF5DB"
                app:cardCornerRadius="17dp"
                app:cardElevation="0dp">

                <TextView
                    android:id="@+id/txtMood"

                    android:layout_width="match_parent"
                    android:layout_height="match_parent"

                    android:gravity="center"

                    android:text="😊"
                    android:textSize="17sp"/>

            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <!-- EDIT -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="38dp"
                android:layout_height="38dp"

                android:layout_marginEnd="8dp"

                app:cardBackgroundColor="#F3EEFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/btnEdit"

                    android:layout_width="match_parent"
                    android:layout_height="match_parent"

                    android:padding="9dp"

                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="#8A63D2"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- DELETE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="38dp"
                android:layout_height="38dp"

                app:cardBackgroundColor="#FFF1F1"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/btnDelete"

                    android:layout_width="match_parent"
                    android:layout_height="match_parent"

                    android:padding="9dp"

                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="#E57373"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- CONTENT -->
        <TextView
            android:id="@+id/txtNoiDung"

            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:layout_marginTop="15dp"

            android:text="Hôm nay là một ngày thật đặc biệt ✨"

            android:textColor="#332C54"
            android:textSize="17sp"
            android:textStyle="bold"

            android:lineSpacingExtra="4dp"

            android:maxLines="4"
            android:ellipsize="end"/>

        <!-- FOOTER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"

            android:layout_marginTop="10dp"

            android:text="Nhật ký cá nhân"

            android:textColor="#B7A8B8"
            android:textSize="12sp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>