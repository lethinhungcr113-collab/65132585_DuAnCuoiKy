<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF9F4"
    android:fitsSystemWindows="true">

    <!-- ALL CONTENT -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="140dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:id="@+id/layoutHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp">

                <!-- BACK BUTTON -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">

                    <ImageView
                        android:id="@+id/btnBack"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:src="?attr/homeAsUpIndicator"
                        app:tint="#7C5AC2" />

                </com.google.android.material.card.MaterialCardView>

                <!-- TITLE -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Viết Nhật Ký"
                    android:textColor="#332C54"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- EMPTY -->
                <View
                    android:layout_width="48dp"
                    android:layout_height="48dp" />

            </LinearLayout>

            <!-- IMAGE CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardImage"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="6dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="5dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F0E5DC"
                app:cardBackgroundColor="#FFFDFB">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- IMAGE -->
                    <ImageView
                        android:id="@+id/imgSelected"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <!-- OVERLAY -->
                    <LinearLayout
                        android:id="@+id/layoutUploadInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical">

                        <!-- ICON -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            app:cardCornerRadius="36dp"
                            app:cardBackgroundColor="#F7EFE7"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="20dp"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="#A06BFF" />

                        </com.google.android.material.card.MaterialCardView>

                        <!-- TEXT -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="Thêm ảnh"
                            android:textColor="#332C54"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Chạm để chụp hoặc chọn ảnh"
                            android:textColor="#A39AAE"
                            android:textSize="14sp" />

                    </LinearLayout>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- CONTENT AREA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <!-- TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Viết cảm xúc hôm nay ✨"
                    android:textColor="#332C54"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!-- SUBTITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Lưu lại những điều bạn đang nghĩ."
                    android:textColor="#9F96A9"
                    android:textSize="15sp" />

                <!-- DIVIDER -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="6dp"
                    android:background="#EEE4DA" />

                <!-- INPUT CARD -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#F1E7DD"
                    app:strokeWidth="1dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <!-- EDITTEXT -->
                        <EditText
                            android:id="@+id/edtContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="180dp"
                            android:maxLines="12"

                            android:background="@android:color/transparent"

                            android:gravity="top|start"
                            android:hint="Hôm nay của bạn thế nào?"

                            android:inputType="textMultiLine|textCapSentences"

                            android:paddingStart="22dp"
                            android:paddingTop="22dp"
                            android:paddingEnd="22dp"
                            android:paddingBottom="60dp"

                            android:textColor="#332C54"
                            android:textColorHint="#B6ACB7"
                            android:textSize="17sp"

                            android:scrollbars="vertical"
                            android:scrollHorizontally="false"

                            android:imeOptions="flagNoExtractUi"/>

                        <!-- COUNTER -->

                    </RelativeLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- SAVE BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="58dp"

        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="15dp"

        android:background="@drawable/background_gradient"

        android:elevation="18dp"
        android:insetTop="0dp"

        android:insetBottom="0dp"
        android:text="LƯU VÀO NHẬT KÝ"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="18sp"

        android:textStyle="bold"
        android:translationZ="19dp"

        app:backgroundTint="@null"
        app:cornerRadius="34dp"
        app:icon="@android:drawable/ic_menu_edit"
        app:iconGravity="textStart"

        app:iconPadding="10dp"
        app:iconTint="#FFFFFF"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>