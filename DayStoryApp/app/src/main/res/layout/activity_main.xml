<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"

    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="@drawable/background_2">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:paddingStart="22dp"
        android:paddingTop="42dp"
        android:paddingEnd="22dp"
        android:paddingBottom="5dp">

        <!-- TOP ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- TITLE -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="DayStory"
                    android:textColor="#332C54"
                    android:textSize="45sp"
                    android:textStyle="bold|italic"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:layout_marginTop="4dp"

                    android:text="Lưu giữ khoảnh khắc của bạn ✨"
                    android:textColor="#F2EFE5"
                    android:textSize="18sp"
                    android:textStyle="bold|italic" />

            </LinearLayout>

            <!-- CHOICE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSort"
                android:layout_width="52dp"
                android:layout_height="52dp"

                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E1AAEB">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_popup_sync"
                    app:tint="#321161" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>



    </LinearLayout>

    <!-- RECYCLER VIEW -->

    <!-- FLOATING BUTTON -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDiaries"
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        android:layout_below="@id/layoutHeader"

        android:layout_marginTop="3dp"
        android:clipToPadding="false"
        android:overScrollMode="never"

        android:paddingTop="4dp"

        android:paddingBottom="120dp"
        tools:listitem="@layout/item_nhat_ky" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnOpenAdd"
        android:contentDescription="Nút thêm nhật ký mới"

        android:layout_width="74dp"
        android:layout_height="74dp"

        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"

        android:layout_marginEnd="24dp"
        android:layout_marginBottom="46dp"

        android:clickable="true"
        android:focusable="true"

        app:cardCornerRadius="37dp"
        app:cardElevation="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            android:background="@drawable/background_gradient">

            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"

                android:layout_centerInParent="true"

                android:src="@android:drawable/ic_input_add"
                app:tint="#FFFFFF" />

        </RelativeLayout>

    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>